# =============================================================================
# LangClaw - environment configuration template
# Copy this file to `.env` and fill in your own keys.
# `.env` is git-ignored; never commit real keys.
# =============================================================================

# --- Required ---
# OpenAI API key (used for the GPT-5-nano agent backbone).
# Obtain at https://platform.openai.com/api-keys
OPEN_AI_API_KEY=sk-REPLACE_ME

# --- Optional ---
# Tavily Search API key. If absent, the SEARCH action falls back to a
# deterministic in-memory pool (still allows the simulation to run offline).
# Obtain at https://app.tavily.com/
TAVILY_API_KEY=tvly-REPLACE_ME
